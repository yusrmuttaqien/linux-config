#!/bin/bash

# --- Configuration ---
# Edit these paths to change your target
LLAMA_EXECUTABLE="/home/yusrmuttaqien/Documents/llama.cpp/main-24-05-2026/build/bin/llama-server"
MODELS_PRESETS="/home/yusrmuttaqien/Documents/llama.cpp/presets.ini"

# Edit these env variables to change your config
export DATA_DIR="$HOME/Documents/Open-WebUI/open-webui"
export WEBUI_SECRET_KEY="top-secret-my-boy"
export GGML_CUDA_ENABLE_UNIFIED_MEMORY=1

# Define commands as functions rather than strings
run_webui() {
  cd ~/Documents/Open-WebUI && source venv/bin/activate && open-webui serve --port 30002
}

run_webui_terminal() {
  cd ~/Documents/Open-WebUI && source venv/bin/activate && open-terminal run --host 0.0.0.0 --port 30004 --api-key top-secret-my-comp
}

run_llama() {
  "$LLAMA_EXECUTABLE" --models-preset "$MODELS_PRESETS" --models-max 1 --host 0.0.0.0 --port 30001 -np 1
}

# --- Execution ---

# 1. Define a cleanup function to safely terminate background jobs
cleanup() {
    echo -e "\n[MAIN] Ctrl+C detected. Gracefully shutting down services..."
    
    # Send SIGTERM to all background jobs started by this script
    kill $(jobs -p) 2>/dev/null
    
    # Wait a moment for them to release VRAM and exit properly
    wait 2>/dev/null 
    echo "[MAIN] All processes successfully closed. VRAM cleared."
    exit 0
}

# 2. Trap the SIGINT (Ctrl+C) and SIGTERM signals and route them to 'cleanup'
trap cleanup SIGINT SIGTERM

# 3. Run commands in the background (no subshell needed now)
run_llama 2>&1 | sed 's/^/[LLM] /' &
run_webui 2>&1 | sed 's/^/[WebUI] /' &
run_webui_terminal 2>&1 | sed 's/^/[WebUI Terminal] /' &

# 4. Use a background sleeper for the message so it doesn't block the interrupt
(sleep 5 && echo -e "\n[MAIN] Open WebUI at localhost:30002 or LLM native UI at localhost:30001. MCPO at localhost:30004") &

# 5. Wait for the background processes
wait
